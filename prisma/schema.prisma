generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  password        String
  name            String?
  role            String            @default("User")
  settings        String            @default("{}")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  favoriteWords   FavoriteWord[]
  quizzes         Quiz[]
  quizAttempts    QuizAttempt[]
  progress        UserProgress[]
  practiceHistory PracticeHistory[]
}

model Word {
  id                  String            @id @default(cuid())
  word                String
  partOfSpeech        Json              @default(value: "[\"unknown\"]")
  senseIndex          Int               @default(0)
  phonetic            String?
  audioUrl            String?
  meaning             String?
  examples            String            @default("[]")
  images              String            @default("[]")
  scenario            String?
  scenarioImages      String            @default("[]")
  exampleSentence     String?
  emotionalConnection String?
  tags                String            @default("[]")
  level               String            @default("A1")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  favorites           FavoriteWord[]
  progress            UserProgress[]
  practiceHistory     PracticeHistory[]

  @@unique([word, senseIndex])
  @@index([level])
}

model UserProgress {
  id             String    @id @default(cuid())
  userId         String
  wordId         String
  learned        Boolean   @default(false)
  masteryLevel   Int       @default(0)
  timesReviewed  Int       @default(0)
  interval       Int       @default(0)
  easeFactor     Float     @default(2.5)
  nextReviewDate DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  word           Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
}

model FavoriteWord {
  id        String   @id @default(cuid())
  userId    String
  wordId    String
  createdAt DateTime @default(now())
  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
}

model PracticeHistory {
  id        String   @id @default(cuid())
  userId    String
  wordId    String
  isCorrect Boolean
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
}

model Quiz {
  id            String        @id @default(cuid())
  title         String
  description   String?
  type          String        @default("MultipleChoice")
  wordIds       String        // Stored as JSON string array of word IDs
  entryPassword String        @unique // 6-digit access code
  isActive      Boolean       @default(true)
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdBy     User          @relation(fields: [createdById], references: [id])
  attempts      QuizAttempt[]
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Int
  total     Int
  details   Json     @default("[]") // Detailed results for each question
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}
